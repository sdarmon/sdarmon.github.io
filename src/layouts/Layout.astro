---
interface Props {
	title: string;
}

const { title } = Astro.props;

// Import de la police (400 = texte normal, 700 = texte en gras)
// C'est mieux d'importer les deux si tu utilises du gras sur ton site !
import '@fontsource/exo-2/400.css';
import '@fontsource/exo-2/700.css';
import { ClientRouter } from 'astro:transitions';
---

<!doctype html>
<html lang="fr">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<meta name="color-scheme" content="dark">
	<meta name="generator" content={Astro.generator} />

	<!-- SEO DE BASE -->
	<title>{title} | Sasha Darmon - Médiation Scientifique & Bio-informatique</title>
	<meta name="description" content="Doctorant en bio-informatique (LBBE Lyon), je conçois et anime des ateliers de vulgarisation scientifique, des expositions et des conférences." />

	<!-- OPEN GRAPH / LINKEDIN / FACEBOOK -->
	<meta property="og:type" content="website" />
	<meta property="og:url" content="https://sashadarmon.fr/" />
	<meta property="og:title" content="Sasha Darmon | Médiation & Recherche" />
	<meta property="og:description" content="Doctorant en Bio-informatique et médiateur scientifique. Découvrez mes ateliers et conférences." />
	<meta property="og:image" content="https://sashadarmon.fr/assets/banner.jpg" />

	<!-- TWITTER -->
	<meta name="twitter:card" content="summary_large_image" />
	<meta name="twitter:title" content="Sasha Darmon | Médiation & Recherche" />
	<meta name="twitter:description" content="Découvrez mes ateliers, mes publications et mon parcours." />
	<meta name="twitter:image" content="https://sashadarmon.fr/assets/banner.jpg" />

	<!-- FAVICONS -->
	<link rel="icon" type="image/svg+xml" href="/assets/profil-40x40.svg" />
	<link rel="apple-touch-icon" href="/assets/profil-40x40.svg" />

	<!-- TRANSITIONS DE PAGE -->
	<ClientRouter />

	<!-- SCRIPTS & STYLES -->
	<link href="/assets/styles.css" rel="stylesheet" type="text/css" />
	<script is:inline>
		!(function (o, c) {
			var n = c.documentElement,
				t = " w-mod-";
			(n.className += t + "js"), ("ontouchstart" in o || (o.DocumentTouch && c instanceof DocumentTouch)) && (n.className += t + "touch");
		})(window, document);
	</script>
</head>
<body>
<slot />
</body>
</html>

<style is:global>
	:root {
		--accent: 136, 58, 234;
		--accent-light: 224, 204, 250;
		--accent-dark: 49, 10, 101;
		--accent-gradient: linear-gradient(
			45deg,
			rgb(var(--accent)),
			rgb(var(--accent-light)) 30%,
			white 60%
		);
	}

	/* 1. On applique Exo 2 à la racine absolue du site */
	html {
		font-family: 'Exo 2', sans-serif;
		background: #13151a ;
		background-size: 224px;
	}

	/* 2. On s'assure que le body hérite bien (par sécurité) */
	body {
		margin: 0; /* Toujours bien de reset la marge par défaut */
	}

	/* 💡 CONSEIL POUR TON PROFIL BIO-INFO / DEVOPS :
	   Généralement, on ne met pas la police principale dans la balise <code>.
	   On garde une police "monospace" pour que le code ressemble à du code !
	   J'ai remis les polices de code standards ici : */
	code {
		font-family:
			Menlo,
			Monaco,
			Lucida Console,
			Liberation Mono,
			DejaVu Sans Mono,
			Bitstream Vera Sans Mono,
			Courier New,
			monospace;
	}

</style>