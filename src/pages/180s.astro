---
import '@fontsource/exo-2/400.css';
import '@fontsource/exo-2/700.css';
---

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>180 Secondes | MT180</title>
    <meta name="color-scheme" content="dark">
</head>
<body>

<a href={import.meta.env.BASE_URL} id="back-button" class="back-link">← Retour</a>
<div class="timer-container">
    <div class="mt180-label">Ma Thèse en</div>
    <div id="number" class="timer-number">180</div>

    <div class="controls">
        <button id="btn-start" class="btn primary">START</button>
        <button id="btn-reset" class="btn secondary">RESET</button>
    </div>
</div>

<!-- is:global EMPÊCHE ASTRO DE SUPPRIMER LES CLASSES ORANGE/ROUGE -->
<style is:global>
    body, html {
        margin: 0;
        padding: 0;
        height: 100vh;
        width: 100vw;
        background-color: #13151a;
        color: white;
        font-family: 'Exo 2', sans-serif;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        overflow: hidden;
    }

    .back-link {
        position: absolute;
        top: 30px;
        left: 30px;
        color: #666;
        text-decoration: none;
        font-size: 14px;
        text-transform: uppercase;
        letter-spacing: 2px;
        transition: color 0.3s;
        z-index: 10;
    }
    .back-link:hover {
        color: #95ec38;
    }

    .timer-container {
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        z-index: 1;
    }

    .mt180-label {
        font-size: 2rem;
        color: #a8a8a8;
        text-transform: uppercase;
        letter-spacing: 5px;
        margin-bottom: -20px;
        font-weight: 700;
    }

    .timer-number {
        font-size: 35vw;
        line-height: 1;
        font-weight: 700;
        margin: 0;
        font-variant-numeric: tabular-nums;
        transition: color 0.3s;
    }

    /* --- LES COULEURS DYNAMIQUES --- */
    .warning {
        color: #ffaa00 !important; /* Orange */
    }

    .danger {
        color: #ff4444 !important; /* Rouge clignotant */
        animation: pulse 1s infinite;
    }

    .negative {
        color: #ff4444 !important; /* Rouge fixe pour le temps dépassé */
    }

    @keyframes pulse {
        0% { transform: scale(1); }
        50% { transform: scale(1.02); text-shadow: 0 0 20px rgba(255, 68, 68, 0.5); }
        100% { transform: scale(1); }
    }

    /* --- LES BOUTONS --- */
    .controls {
        display: flex;
        gap: 20px;
        margin-top: 5vh;
    }

    .btn {
        padding: 15px 40px;
        font-size: 24px;
        border-radius: 12px;
        border: none;
        font-family: 'Exo 2', sans-serif;
        font-weight: bold;
        cursor: pointer;
        transition: all 0.2s;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .primary {
        background-color: #95ec38;
        color: #13151a;
        box-shadow: 0 0 15px rgba(149, 236, 56, 0.3);
    }
    .primary:hover {
        background-color: #ffffff;
        box-shadow: 0 0 25px rgba(255, 255, 255, 0.4);
    }

    .secondary {
        background-color: transparent;
        color: #666;
        border: 2px solid #333;
    }
    .secondary:hover {
        color: #fff;
        border-color: #fff;
    }

    @media (max-width: 768px) {
        .timer-number { font-size: 45vw; }
        .btn { font-size: 18px; padding: 12px 30px; }
        .mt180-label { font-size: 1.2rem; }
    }
</style>

<script is:inline>
    var seconds = 180;
    var interval = null;
    var isRunning = false;

    var numberDisplay = document.getElementById('number');
    var btnStart = document.getElementById('btn-start');
    var btnReset = document.getElementById('btn-reset');

    function updateDisplay() {
        if (!numberDisplay) return;

        numberDisplay.innerText = seconds;

        // Logique des couleurs
        if (seconds <= 30 && seconds > 10) {
            numberDisplay.className = 'timer-number warning'; // Orange
        } else if (seconds <= 10 && seconds > 0) {
            numberDisplay.className = 'timer-number danger'; // Rouge qui bat
        } else if (seconds <= 0) {
            numberDisplay.className = 'timer-number negative'; // Temps dépassé !
        } else {
            numberDisplay.className = 'timer-number'; // Normal
        }
    }

    if (btnStart) {
        btnStart.onclick = function() {
            if (isRunning) {
                // Clic sur PAUSE
                clearInterval(interval);
                btnStart.innerText = 'REPRENDRE';
                isRunning = false;
            } else {
                // Clic sur START / REPRENDRE
                interval = setInterval(function() {
                    seconds--; // Continue de descendre même en négatif
                    updateDisplay();
                }, 1000);
                btnStart.innerText = 'PAUSE';
                isRunning = true;
            }
        };
    }

    if (btnReset) {
        btnReset.onclick = function() {
            clearInterval(interval);
            isRunning = false;
            seconds = 180;
            if (btnStart) {
                btnStart.innerText = 'START';
            }
            updateDisplay();
        };
    }
    document.getElementById('back-button').addEventListener('click', (e) => {
    // Si l'utilisateur a une page précédente sur ton site
    if (document.referrer && document.referrer.includes(window.location.hostname)) {
    e.preventDefault(); // On empêche le lien vers l'accueil
    history.back();     // On retourne à la page précédente
}
    // Sinon, on laisse le lien normal (href) s'exécuter vers l'accueil
});
</script>
</body>
</html>