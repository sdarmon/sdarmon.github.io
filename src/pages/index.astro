---
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";
import Footer from "../components/Footer.astro";

import "../layouts/index.css";


import { Image } from 'astro:assets';

// 2. On importe les vrais fichiers images depuis src/assets/
import ateliersImg from '../assets/frise geek touch caree.jpg';
import prixImg from '../assets/Bartok_Vincent_Noclin.jpg';
import rechercheImg from '../assets/comp_legende_EN_carre.png';
import cvImg from '../assets/adn.jpg';
---


<!DOCTYPE html>
<html
>
  <Header title="Sasha Darmon" />
  <body>
    <div class="content">
      <Sidebar selectedItem="home" />
      <nav class="main">
        <div class="container">
          <main class="fold-content-container">
            <div class="fold-content">
              <h1>Sasha Darmon</h1>
              <div class="mini-label-white gray-color" >
                Médiation & Recherche
              </div>
              <p class="lead">
                Doctorant en bio-informatique au LBBE à Lyon, je suis engagé dans la médiation
                scientifique. Je suis également président de l'association de vulgarisation scientifique <i style="color: #95ec38; font-weight: 700;">Démesures</i>,
                avec qui nous organisons des événements pour rendre la science accessible à tous.
                N'hésitez pas à me contacter pour discuter de vos projets ou de collaborations potentielles !
              </p>

              <!-- Titre de la section mosaïque (optionnel) -->
              <div class="mini-label-white gray-color">
                Explorer mon univers
              </div>

              <!-- La Mosaïque 2x2 -->
              <div class="mosaic-grid" style="display: grid !important; grid-template-columns: repeat(2, minmax(0, 1fr)) !important; gap: 20px !important; width: 100% !important;">

                <a href="/ateliers" class="mosaic-card" style="display: flex !important; width: 100% !important;">
                  <div class="mosaic-overlay"></div>
                  <Image src={ateliersImg} alt="Ateliers de médiation mis en place à la Japan Touch Haru par Sasha Darmon pour l'association Démesures" class="mosaic-img" />
                  <div class="mosaic-content">
                    <h3>Ateliers de médiation</h3>
                    <p style="color: #95ec38 !important; font-weight: 500;">Conception & Animation</p>
                  </div>
                </a>

                <a href="/communication-prix" class="mosaic-card" style="display: flex !important; width: 100% !important;">
                  <div class="mosaic-overlay"></div>
                  <Image src={prixImg} alt="Prix et conférences de médiation scientifiques. Image de la couverture de la BD Mission Z." class="mosaic-img" />
                  <div class="photo-credit-vertical-index">© Vincent Noclin</div>
                  <div class="mosaic-content">
                    <h3>Communication & prix</h3>
                    <p style="color: #95ec38 !important; font-weight: 500;">MT180, BD, Fête de la Science</p>
                  </div>
                </a>

                <a href="/publications" class="mosaic-card" style="display: flex !important; width: 100% !important;">
                  <div class="mosaic-overlay"></div>
                  <Image src={rechercheImg} alt="Image d'un extended t-core. Article de recherche Sasha Darmon" class="mosaic-img" />
                  <div class="mosaic-content">
                    <h3>Publications</h3>
                    <p style="color: #95ec38 !important; font-weight: 500;">Articles & Recherche</p>
                  </div>
                </a>

                <a href="/cv" class="mosaic-card" style="display: flex !important; width: 100% !important;">
                  <div class="mosaic-overlay"></div>
                  <Image src={cvImg} alt="Simulation de morceaux d'ADN pour illuster mon CV" class="mosaic-img" />
                  <div class="photo-credit-vertical-index">© Unsplash/CC0 Public Domain</div>
                  <div class="mosaic-content">
                    <h3>Mon CV</h3>
                    <p style="color: #95ec38 !important; font-weight: 500;">Parcours & compétences</p>
                  </div>
                </a>

              </div>

              <div class="mini-label-white gray-color">
                Contact
              </div>


            <div class="button-group">
              <a href="https://www.linkedin.com/in/sashadarmon/" target="_blank" class="button w-button linkedin-btn">
                <img src="/assets/LinkedIn_icon.svg" alt="Icon LinkdeIn" class="btn-icon" />
                LinkedIn
              </a>
              <a href="/contact" target="_blank" class="button w-button contact-btn" >
                Me contacter
              </a>
            </div>


              <blockquote class="scientific-quote">
                <p>"Il n'y a pas de lendemains qui chantent. Il n'y a que des aujourd'hui qui bruissent."</p>
                <footer>
                  — <span class="author">Alain Damasio</span>, <cite>Les Furtifs</cite>
                </footer>
              </blockquote>
            </div>

          </main>
          <Footer />
        </div>
      </nav>

    </div>


    <!--[if lte IE 9]><script src="//cdnjs.cloudflare.com/ajax/libs/placeholders/3.0.2/placeholders.min.js"></script><![endif]-->
  </body>
</html>
