---
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";
import Footer from "../components/Footer.astro";
import "../layouts/index.css";
---

<!DOCTYPE html>
<html>
<Header title="Contact | Sasha Darmon" />
<body>
<div class="content">
    <!-- On peut laisser selectedItem vide si tu n'as pas de bouton Contact dans ta sidebar -->
    <Sidebar selectedItem="contact" />
    <nav class="main">
        <div class="container">
            <main class="fold-content-container">

                <a href="/" class="button w-button" style="margin-bottom: 32px; background-color: #353535; border-color: #353535;">← Retour</a>

                <div class="fold-content">
                    <h1>Travaillons ensemble</h1>
                    <p class="lead" style="margin-bottom: 40px;">
                        Un projet d'atelier de médiation, une conférence, ou une collaboration scientifique ?
                        N'hésitez pas à m'écrire via le formulaire ci-dessous ou directement sur mes réseaux.
                    </p>

                    <!-- Les boutons de contact rapides (Mail & LinkedIn) -->
                    <div class="button-group" style="display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 60px;">
                        <a href="https://www.linkedin.com/in/sashadarmon/" target="_blank" class="button w-button linkedin-btn">
                            <img src="/assets/LinkedIn_icon.svg" alt="Icon Linkedin" class="btn-icon" />
                            LinkedIn
                        </a>
                        <a href="mailto:contact@sashadarmon.fr" class="button w-button contact-btn">E-mail</a>
                    </div>

                    <!-- Le Formulaire de contact -->
                    <div class="mini-label-white gray-color" style="margin-bottom: 24px; font-size: 14px; letter-spacing: 1.5px;">
                        Ou laissez-moi un message
                    </div>

                    <!-- REMPLACE L'URL "YOUR_FORMSPREE_ENDPOINT" par celle que Formspree te donnera -->
                    <form action="https://formspree.io/f/mwvwnnnp" method="POST" class="contact-form">

                        <div class="form-group">
                            <label for="name">Votre nom / Institution</label>
                            <input type="text" id="name" name="name" required placeholder="Ex: Laboratoire de ..." />
                        </div>

                        <div class="form-group">
                            <label for="email">Votre adresse email</label>
                            <input type="email" id="email" name="_replyto" required placeholder="exemple@domaine.com" />
                        </div>

                        <div class="form-group">
                            <label for="message">Votre message</label>
                            <textarea id="message" name="message" required rows="5" placeholder="Bonjour Sasha,nous aimerions organiser un atelier..."></textarea>
                        </div>

                        <!-- Ce champ caché empêche les robots de spammer ton formulaire -->
                        <input type="text" name="_gotcha" style="display:none" />

                        <button type="submit" class="button w-button submit-btn">Envoyer le message</button>
                    </form>

                </div>

            </main>
            <Footer />
        </div>
    </nav>
</div>

</body>
</html>