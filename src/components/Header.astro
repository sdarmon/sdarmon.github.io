---
import { ui } from '@/i18n/ui';
import { ClientRouter } from 'astro:transitions';
import '@fontsource/exo-2/400.css';
import '@fontsource/exo-2/700.css';

interface HeaderProps {
  title: string;
}
const { title } = Astro.props as HeaderProps;

// Logique de langue
const pathname = Astro.url.pathname;
const lang = pathname.startsWith('/en') ? 'en' : 'fr';
const t = ui[lang];

// Construction du titre final
const finalTitle = `${title} | Sasha Darmon - ${t['seo.suffix']}`;
//Image
const ogImage = lang === 'en'
    ? 'https://sashadarmon.fr/assets/banner-en.jpg'
    : 'https://sashadarmon.fr/assets/banner.jpg';
---

<head prefix="og: http://ogp.me/ns#">
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="color-scheme" content="dark">
  <meta name="generator" content={Astro.generator} />
  <meta name="author" content="Sasha Darmon" />
  <meta name="thumbnail" content="https://sashadarmon.fr/photo/Bartok_Vincent_Noclin.jpg" />

  <!-- SEO CLASSIQUE -->
  <title>{finalTitle}</title>
  <meta name="description" content={t['seo.description']} />

  <!-- OPEN GRAPH / LINKEDIN / FACEBOOK -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={Astro.url} />
  <meta property="og:title" content={finalTitle} />
  <meta property="og:description" content={t['seo.ogDescription']} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="Sasha Darmon" />

  <!-- TWITTER -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={finalTitle} />
  <meta name="twitter:description" content={t['seo.ogDescription']} />
  <meta name="twitter:image" content="https://sashadarmon.fr/assets/banner.jpg" />

  <!-- FAVICONS -->
  <link rel="icon" type="image/svg+xml" href="/assets/profil-40x40.svg" />
  <link rel="apple-touch-icon" href="/assets/profil-40x40.svg" />

  <!-- MULTILINGUE -->
  <link rel="alternate" hreflang="fr" href="https://sashadarmon.fr/" />
  <link rel="alternate" hreflang="en" href="https://sashadarmon.fr/en/" />

  <!-- TRANSITIONS DE PAGE -->
  <ClientRouter />

  <!-- SCRIPTS & STYLES -->
  <link href="/assets/styles.css" rel="stylesheet" type="text/css" />

  <script is:inline>
    !(function (o, c) {
      var n = c.documentElement,
          t = " w-mod-";
      (n.className += t + "js"), ("ontouchstart" in o || (o.DocumentTouch && c instanceof DocumentTouch)) && (n.className += t + "touch");
    })(window, document);
  </script>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Sasha Darmon",
      "url": "https://sashadarmon.fr",
      "image": "https://sashadarmon.fr/photo/Bartok_Vincent_Noclin.jpg",
      "description": "Doctorant en bio-informatique et médiateur scientifique.",
      "jobTitle": "Doctorant",
      "affiliation": {
        "@type": "Organization",
        "name": "LBBE - Université de Lyon"
      }
    }
  </script>
</head>